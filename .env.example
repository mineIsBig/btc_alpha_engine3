# === Database ===
DATABASE_URL=sqlite:///./btc_alpha.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/btc_alpha

# === Coinalyze (replaces CoinGlass) ===
# Sign up at coinalyze.net and generate an API key at https://api.coinalyze.net/v1/doc/
COINALYZE_API_KEY=your_coinalyze_api_key_here

# === Hyperliquid (optional - not used for live trading in agent mode) ===
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_BASE_URL=https://api.hyperliquid-testnet.xyz

# === Targon (CPU compute + inference) ===
# Get API key from targon.com
TARGON_API_KEY=
TARGON_BASE_URL=https://api.targon.com/v1
TARGON_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# === Lium (GPU rental for training) ===
# Authenticate via: pip install lium.io && lium init
LIUM_API_KEY=

# === Chutes.ai (serverless agent inference) ===
# Get API key from chutes.ai
CHUTES_API_KEY=
CHUTES_BASE_URL=https://llm.chutes.ai/v1
CHUTES_MODEL=deepseek-ai/DeepSeek-V3-0324

# === Feature Flags ===
LIVE_TRADING_ENABLED=false
PAPER_MODE=true
FLATTEN_ON_BREACH=true

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Risk ===
DAILY_LOSS_LIMIT_PCT=0.05
EOD_TRAILING_LOSS_LIMIT_PCT=0.05

# === Agent ===
AGENT_DELAY_SECONDS=3600
AGENT_EQUITY=100000

# === Monitoring ===
PROMETHEUS_PORT=9090
